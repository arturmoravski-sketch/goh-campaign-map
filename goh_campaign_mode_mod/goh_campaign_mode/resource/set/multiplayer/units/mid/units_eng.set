;SDL

;////////////////// INSTRUCTIONS //////////////////
;Buttons go as follows, displayed in-game in this order:

; inf1       - infantry squads
; inf2       - infantry single units
; empl       - Emplacements, AA, AT, Mortars, Howitzers
; vehicles   - vehicles, armoured cars, supplies
; tanks      - main battle tanks, TDs, SPGs
; doctrine   - specific doctrine setups

; TEMP: Note all levels have been brought down to 1 to remove unit locks.
; Squads currently have an MP cost of 0 - their cost is currently calculated as the sum of their soldiers cost, see inf_ger.set
; Check ../settings.set for syntax instructions!!
; unit limits per game are not defined here but in gamemode presets

;user defined set tags that should be featured on units:
;all artillery heavyart cannon mediumcan heavycan light medium heavy infantry supply
;these tags allow player to disable certain sets for custom setups like "no heavy artillery" 
;//////////////////////////////////////////////////


;_________________________________________________
;|            Doctrine                            |
;|________________________________________________|


;===================================
;       ALL-ROUND DOCTRINE
;===================================


; ======Tier1======

; // squad_1st_airland_support
{"doctrine_squad_1st_airland_support_mid_all(eng)"
	("squad_with4types_doctrine" side(eng) period(mid) c1(1st_air_land_sec_com:1) c2(1st_air_land_sniper:1) c3(1st_air_land_mg:1) c4(1st_air_land_mg_asst:1)) 
	("doctrine_t1" cool(150) d(mid_eng_allround) cost(10))
	{tags "limit4"}
}

; // aec_mk1
{"doctrine_aec_mk1"
	("squad_vehicle2_doctrine" side(eng) period(mid) vehicle(aec_mk1) crew1(vehicle_crew:2) crew2(vehicle_com_sgt:1))
	("doctrine_t1" cool(240) d(mid_eng_allround) cost(10))
	{tags "limit3"}
}

; // cruiser_mk2a_cs
{"doctrine_cruiser_mk2a_cs_mid"
	("squad_vehicle2_doctrine" side(eng) period(mid) vehicle(cruiser_mk2a_cs) crew1(tankman:4) crew2(tank_commander:1))
	("doctrine_t1" cool(300) d(mid_eng_allround) cost(30))
}


; ======Tier2======

; // churchill_mk3_l50
{"doctrine_churchill_mk3"
	("squad_vehicle2_doctrine" side(eng) period(mid) vehicle(churchill_mk3_l50) crew1(tankman:4) crew2(tank_commander_m1928:1))
	("doctrine_t2" cool(300) d(mid_eng_allround) cost(50))
}

; // Artillery Signaller
{"doctrine_squad_eng_signaller_88_mid(eng)"
	("squad_with1types_doctrine" side(eng) period(mid) c1(fo_radio_88:1))
	("doctrine_t2" cool(300) d(mid_eng_allround) cost(60))
	{tags "signaller"}
}

; // bishop
{"doctrine_bishop"
	("squad_vehicle2_doctrine" side(eng) period(mid) vehicle(bishop) crew1(tankman:3) crew2(tank_commander_m1928:1))
	("doctrine_t2" cool(300) d(mid_eng_allround) cost(80))
}


; ======Tier3======

; // Artillery Signaller
{"doctrine_squad_eng_signaller_183_mid(eng)"
	("squad_with1types_doctrine" side(eng) period(mid) c1(fo_radio_183:1))
	("doctrine_t3" cool(480) d(mid_eng_allround) cost(60))
	{tags "signaller_heavy"}
}

; // 152mm_bl_6
{"doctrine_152mm_bl_6_mid"
	("towed_gun_doctrine" side(eng) period(mid) vehicle(morris_c8) crew_v(driver:1) cannon(152mm_bl_6) crew_c(artilleryman:5))
	("doctrine_t3" cool(480) d(mid_eng_allround) cost(80))
}

; // 155mm_m1a1_longtom_eng
{"doctrine_155mm_m1a1_longtom_eng_mid"
	("towed_gun_doctrine" side(eng) period(mid) vehicle(morris_c8) crew_v(driver:1) cannon(155mm_m1a1_longtom_eng) crew_c(artilleryman:5))
	("doctrine_t3" cool(480) d(mid_eng_allround) cost(100))
	{tags "limitf1"}
}

