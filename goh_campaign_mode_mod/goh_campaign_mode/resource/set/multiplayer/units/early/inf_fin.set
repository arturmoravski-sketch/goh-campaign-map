;SDL

;===================================
;        INSTRUCTIONS    
;===================================

; In this file onee configures the humans which are spawned in vehicles or squads
; The humans have a CP and cost associated with them which collectively add up for the final squad value
; Check ../settings_inf.set for the global defines for CP, capture weight (CW), score, etc.

;===================================
;        PRICING CHART	       
;===================================

; // Standard prices below are for tier2 infantry

;mosin			= 8
;kiv96 			= 8
;m27 			= 8
;m39 			= 8
;svt38/40 		= 12
;avt40 			= 14
;pps43 			= 10
;mp28 			= 10
;m20 			= 10 or 13 if above t2
;m31 stick 		= 10 or 13 if above t2
;m31 drum 		= 14
;ppsh41 drum	= 14
;chauchat 		= 20
;pk21 			= 25
;madsen 		= 25
;m26 			= 25
;dp27 			= 35
;dt 			= 35
;rifle grenade 	= +5
;marksman 		= +2
;any % pzfaust 	= +0
;any pzfaust 	= +0
;any flamer		= 60
;engineer		= 50
;miner 			= 40

; // price modifiers (If not tier2)
;tier 0 		= -3, MG -10
;tier 1 		= -1, MG -10
;tier 1 vet 	= 0, MG 0
;tier 2 vet		= +2, MG +5
;tier 3 		= +5, MG +10
;tier 3 vet 	= +8, MG +15
;tier 4 		= +10, MG +20
;tier 4 vet 	= +12, MG +25


