;SDL

;////////////////// INSTRUCTIONS //////////////////
;Buttons go as follows, displayed in-game in this order:

; inf1       - infantry squads
; inf2       - infantry single units
; empl       - Emplacements, AA, AT, Mortars, Howitzers
; vehicles   - vehicles, armoured cars, supplies
; tanks      - main battle tanks, TDs, SPGs
; doctrine   - specific doctrine setups

; TEMP: Note all levels have been brought down to 1 to remove unit locks.
; Squads currently have an MP cost of 0 - their cost is currently calculated as the sum of their soldiers cost, see inf_ger.set
; Check ../settings.set for syntax instructions!!
; unit limits per game are not defined here but in gamemode presets

;user defined set tags that should be featured on units:
;all artillery heavyart cannon mediumcan heavycan light medium heavy infantry supply
;these tags allow player to disable certain sets for custom setups like "no heavy artillery" 
;//////////////////////////////////////////////////


;_________________________________________________
;|            Doctrine                            |
;|________________________________________________|


;===================================
;       ALL-ROUND DOCTRINE
;===================================


; ======Tier1======

; // mortar_carrier_mk1
{"doctrine_mortar_carrier_mk1"
	("squad_vehicle2_doctrine" side(eng) period(early) vehicle(mortar_carrier_mk1_boys) crew1(driver:1) crew2(crew:3))
	("doctrine_t1" cool(180) d(early_eng_allround) cost(5))
	{tags "limit5"}
}

; // Bren Carrier Group
{"doctrine_squad_carrier_early_all"
	("squad_eng_carrier_doctrine" side(eng) period(early) crew1(driver:1) crew2(rifle:1) vehicle1(bren_carrier_boys) c1(sec_com_sgt:1) vehicle2(bren_carrier) c2(detach_com_cpl:1) vehicle3(bren_carrier) c3(detach_com_cpl:1)) 
	("doctrine_t1" cool(180) d(early_eng_allround) cost(15))
}

; // cruiser_mk3
{"doctrine_cruiser_mk3"
	("squad_vehicle2_doctrine" side(eng) period(early) vehicle(cruiser_mk3) crew1(tankman:3) crew2(tank_commander:1))
	("doctrine_t1" cool(180) d(early_eng_allround) cost(15))
}


; ======Tier2======

; // Artillery Signaller
{"doctrine_squad_eng_signaller_88_early(eng)"
	("squad_with1types_doctrine" side(eng) period(early) c1(fo_radio_88:1))
	("doctrine_t2" cool(300) d(early_eng_allround) cost(60))
	{tags "signaller"}
}

; // Matilda1
{"doctrine_matilda1"
	("squad_vehicle2_doctrine" side(eng) period(early) vehicle(matilda1) crew1(tankman:1) crew2(tank_commander:1))
	("doctrine_t2" cool(300) d(early_eng_allround) cost(35))
}

; // matilda2_mk1
{"doctrine_matilda2_mk1_early"
	("squad_vehicle2_doctrine" side(eng) period(early) vehicle(matilda2_mk1) crew1(tankman:3) crew2(tank_commander:1))
	("doctrine_t2" cool(300) d(early_eng_allround) cost(65))
}


; ======Tier3======

; // Artillery Signaller
{"doctrine_squad_eng_signaller_203_early(eng)"
	("squad_with1types_doctrine" side(eng) period(early) c1(fo_radio_203:1))
	("doctrine_t3" cool(480) d(early_eng_allround) cost(60))
	{tags "signaller_heavy"}
}

; // 152mm_bl_6
{"doctrine_152mm_bl_6_early"
	("towed_gun_doctrine" side(eng) period(early) vehicle(morris_c8) crew_v(driver:1) cannon(152mm_bl_6) crew_c(artilleryman:5))
	("doctrine_t3" cool(480) d(early_eng_allround) cost(80))
}


