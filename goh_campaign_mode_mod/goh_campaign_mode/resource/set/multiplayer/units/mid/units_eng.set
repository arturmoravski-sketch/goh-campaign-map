; // Light Airstrike
{"doctrine_hurribomber_mk2c_light"
	("squad_vehicle_doctrine" side(eng) period(mid) vehicle(hurribomber_mk2c) crew(pilot:1))
	("doctrine_t1" cool(360) d(mid_eng_irregular) cost(10))
	{action "airstrike:250lb_gp_mk4"}
	{tags "limit3"}
}

; // Bren Carrier Group
{"doctrine_squad_carrier_mid_irr"
