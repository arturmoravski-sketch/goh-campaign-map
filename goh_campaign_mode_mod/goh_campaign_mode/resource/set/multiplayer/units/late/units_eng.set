;SDL

;////////////////// INSTRUCTIONS //////////////////
;Buttons go as follows, displayed in-game in this order:

; inf1       - infantry squads
; inf2       - infantry single units
; empl       - Emplacements, AA, AT, Mortars, Howitzers
; vehicles   - vehicles, armoured cars, supplies
; tanks      - main battle tanks, TDs, SPGs
; doctrine   - specific doctrine setups

; TEMP: Note all levels have been brought down to 1 to remove unit locks.
; Squads currently have an MP cost of 0 - their cost is currently calculated as the sum of their soldiers cost, see inf_ger.set
; Check ../settings.set for syntax instructions!!
; unit limits per game are not defined here but in gamemode presets

;user defined set tags that should be featured on units:
;all artillery heavyart cannon mediumcan heavycan light medium heavy infantry supply
;these tags allow player to disable certain sets for custom setups like "no heavy artillery" 
;//////////////////////////////////////////////////


;_________________________________________________
;|            Doctrine                            |
;|________________________________________________|


;===================================
;       ALL-ROUND DOCTRINE
;===================================


; ======Tier1======

; // squad_1st_airland_support
{"doctrine_squad_1st_airland_support_late_all(eng)"
	("squad_with4types_doctrine" side(eng) period(late) c1(1st_air_land_sec_com_cpl:1) c2(1st_air_land_sniper:1) c3(1st_air_land_mg:1) c4(1st_air_land_mg_asst:1))
	("doctrine_t1" cool(150) d(late_eng_allround) cost(10))
	{tags "limit4"}
}

; // crusader_aa_mk2
{"doctrine_crusader_aa_mk2"
	("squad_vehicle2_doctrine" side(eng) period(late) vehicle(crusader_aa_mk2) crew1(vehicle_crew:3) crew2(vehicle_com_cpl:1))
	("doctrine_t1" cool(240) d(late_eng_allround) cost(20))
}

; // staghound_mk2
{"doctrine_staghound_mk2"
	("squad_vehicle2_doctrine" side(eng) period(late) vehicle(staghound_mk2) crew1(vehicle_crew:3) crew2(vehicle_com_cpl:1))
	("doctrine_t1" cool(300) d(late_eng_allround) cost(30))
}


; ======Tier2======

; // Artillery Signaller
{"doctrine_squad_eng_signaller_88_late(eng)"
	("squad_with1types_doctrine" side(eng) period(late) c1(fo_radio_88:1))
	("doctrine_t2" cool(300) d(late_eng_allround) cost(60))
	{tags "signaller"}
}

; // achilles_mk2
{"doctrine_achilles_mk2"
	("squad_vehicle2_doctrine" side(eng) period(late) vehicle(achilles_mk2) crew1(tankman:4) crew2(tank_commander:1))
	("doctrine_t2" cool(300) d(late_eng_allround) cost(70))
}

; // sexton_mk2
{"doctrine_sexton_mk2"
	("squad_vehicle2_doctrine" side(eng) period(late) vehicle(sexton_mk2) crew1(tankman:5) crew2(tank_commander:1))
	("doctrine_t2" cool(300) d(late_eng_allround) cost(80))
}


